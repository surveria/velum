+    private func storeTimedOutProgram(_ program: Program) {
+        let hasTimeoutInfo = program.comments.at(.footer)?.contains("TIMEOUT INFO") ?? false
+        if !hasTimeoutInfo {
+            program.comments.add("TIMEOUT INFO", at: .footer)
+            program.comments.add("============", at: .footer)
+            if let tag = fuzzer.config.tag {
+                program.comments.add("INSTANCE TAG: \(tag)", at: .footer)
+            }
+            program.comments.add(
+                "FUZZER ARGS: \(fuzzer.config.arguments.joined(separator: " "))", at: .footer)
+            program.comments.add(
+                "TARGET ARGS: \(fuzzer.runner.processArguments.joined(separator: " "))",
+                at: .footer)
+        }
+
+        let filename = "program_\(formatDate())_\(program.id)"
+        storeProgram(program, as: filename, in: timeOutDir)
+    }
