*

!/.gitignore
!/Cargo.toml
!/Cargo.lock
!/README.md
!/AGENTS.md
!/CLAUDE.md

!/.github/
!/.github/workflows/
!/.github/workflows/ci.yml

!/reports/
!/reports/test-runs/
!/reports/test-runs/*.md

!/scripts/
!/scripts/*.sh

!/docs/
!/docs/*.md

!/src/
!/src/**/
!/src/**/*.rs

!/tests/
!/tests/**/
!/tests/**/*.md
!/tests/**/*.rs
!/tests/**/*.js
