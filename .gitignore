*

!/.gitignore
!/Cargo.toml
!/Cargo.lock
!/README.md
!/AGENTS.md
!/CLAUDE.md

!/.github/
!/.github/workflows/
!/.github/workflows/ci.yml

!/reports/
!/reports/*.jpg
!/reports/*.md
!/reports/test-runs/
!/reports/test-runs/*.md

!/scripts/
!/scripts/*.sh

!/docs/
!/docs/*.md

!/src/
!/src/**/
!/src/**/*.rs

!/runner/
!/runner/.gitignore
!/runner/Cargo.toml
!/runner/Cargo.lock
!/runner/README.md
!/runner/src/
!/runner/src/**/
!/runner/src/**/*.rs

!/tests/
!/tests/**/
!/tests/**/*.md
!/tests/**/*.rs
!/tests/**/*.js
!/tests/**/*.tsv
